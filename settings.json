{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Edit|Write|MultiEdit|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/scripts/guard-secrets.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/scripts/push-guard.sh"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/scripts/recast-commit-gate.py",
            "timeout": 600
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/scripts/style-check.sh"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/scripts/shellcheck-check.sh"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/scripts/ruff-check.sh"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/scripts/style-check-test.sh"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/scripts/sync-docs-check.sh"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/scripts/sync-docs-test.sh"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/scripts/guard-secrets-test.sh"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/scripts/recast-test.sh"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/scripts/md-links-check.py"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/scripts/md-links-check-test.sh"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/scripts/markdownlint-check.sh"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/scripts/markdownlint-check-test.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "code-review@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true
  }
}
